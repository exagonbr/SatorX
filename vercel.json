{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npx -y npm@10.9.2 ci --omit=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "src/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "excludeFiles": "src/public/**"
    }
  }
}
