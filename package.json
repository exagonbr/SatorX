{
  "name": "sator-chess-engine",
  "version": "0.6.0",
  "description": "Motor de xadrez (8x8) com avaliação Sator + heurísticas Sun Tzu e Kasparov-style.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "npx prisma generate",
    "db:init": "node scripts/init-ai-db.js",
    "db:migrate": "npx prisma migrate deploy",
    "db:migrate:dev": "npx prisma migrate dev",
    "deploy:prod": "bash scripts/deploy-prod.sh",
    "certs:self": "bash scripts/gen-selfsigned-cert.sh",
    "start": "node src/index.js bestmove",
    "analyze": "node src/index.js analyze",
    "bestmove": "node src/index.js bestmove",
    "selfplay": "node src/tools/selfplay.js",
    "suite": "node src/tools/tacticalSuite.js",
    "server": "node src/server.js",
    "evolve": "node src/tools/evolve.js",
    "replay": "node src/tools/replayTrain.js",
    "build-buffer": "node src/tools/buildReplayBuffer.js",
    "train-buffer": "node src/tools/trainFromBuffer.js",
    "train-buffer-file": "node src/tools/trainFromBuffer.js --file",
    "seed-kasparov": "node src/tools/seedKasparov.js",
    "seed-masters": "node src/tools/seedMasters.js",
    "pwa:icons": "node src/tools/generatePwaIcons.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "prisma": "^6.19.2",
    "chess.js": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
